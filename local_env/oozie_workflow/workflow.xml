<?xml version="1.0" encoding="UTF-8"?>
<workflow-app name="Stock_BigData_Pipeline_Final" xmlns="uri:oozie:workflow:0.4">

    <start to="sqoop-import-node"/>

    <action name="sqoop-import-node">
        <sqoop xmlns="uri:oozie:sqoop-action:0.4">
            <job-tracker>${jobTracker}</job-tracker>
            <name-node>${nameNode}</name-node>
            <prepare>
                <delete path="${nameNode}/user/hadoop/stock_raw"/>
            </prepare>
            <arg>import</arg>
            <arg>--connect</arg>
            <arg>jdbc:mysql://localhost:3306/bigdata_stock</arg>
            <arg>--username</arg>
            <arg>root</arg>
            <arg>--password</arg>
            <arg>123456</arg> 
            <arg>--table</arg>
            <arg>tbl_raw_stock</arg>
            <arg>--target-dir</arg>
            <arg>/user/hadoop/stock_raw</arg>
            <arg>-m</arg>
            <arg>1</arg>
        </sqoop>
        <ok to="hive-clean-node"/>
        <error to="fail"/>
    </action>

    <action name="hive-clean-node">
        <hive xmlns="uri:oozie:hive-action:0.2">
            <job-tracker>${jobTracker}</job-tracker>
            <name-node>${nameNode}</name-node>
            <job-xml>/home/hadoop/hive/conf/hive-site.xml</job-xml>
            <script>/home/hadoop/clean_data_advanced.hql</script>
        </hive>
        <ok to="mapreduce-tasks-node"/>
        <error to="fail"/>
    </action>

    <action name="mapreduce-tasks-node">
        <shell xmlns="uri:oozie:shell-action:0.2">
            <job-tracker>${jobTracker}</job-tracker>
            <name-node>${nameNode}</name-node>
            <exec>sh</exec>
            <argument>run_all_mapreduce.sh</argument>
            <file>/home/hadoop/mapreduce/run_all_mapreduce.sh#run_all_mapreduce.sh</file>
        </shell>
        <ok to="pyspark-join-kafka-node"/>
        <error to="fail"/>
    </action>

    <action name="pyspark-join-kafka-node">
        <shell xmlns="uri:oozie:shell-action:0.2">
            <job-tracker>${jobTracker}</job-tracker>
            <name-node>${nameNode}</name-node>
            <exec>spark-submit</exec>
            <argument>--packages</argument>
            <argument>org.apache.spark:spark-sql-kafka-0-10_2.12:3.4.1</argument>
            <argument>spark_master_pipeline.py</argument>
            <file>/home/hadoop/bigdata_spark/spark_master_pipeline.py#spark_master_pipeline.py</file>
        </shell>
        <ok to="end"/>
        <error to="fail"/>
    </action>

    <kill name="fail">
        <message>Lỗi! Hệ thống Big Data dừng ở Node: [${wf:errorMessage(wf:lastErrorNode())}]</message>
    </kill>

    <end name="end"/>

</workflow-app>